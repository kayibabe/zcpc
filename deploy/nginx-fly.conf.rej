diff a/deploy/nginx-fly.conf b/deploy/nginx-fly.conf	(rejected hunks)
@@ -7,6 +7,13 @@ server {
 
     client_max_body_size 20M;
 
+    # Security headers
+    add_header X-Frame-Options "SAMEORIGIN" always;
+    add_header X-Content-Type-Options "nosniff" always;
+    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
+    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.base44.app wss://*.base44.app;" always;
+    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
+
     # Serve the React SPA — fall back to index.html for client-side routes
     location / {
         try_files $uri $uri/ /index.html;
@@ -40,3 +47,4 @@ server {
         proxy_set_header Host $host;
     }
 }
