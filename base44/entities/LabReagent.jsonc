{
  "name": "LabReagent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Reagent or consumable name"
    },
    "catalogue_number": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "reagent",
        "consumable",
        "calibrator",
        "control",
        "stain",
        "media",
        "other"
      ]
    },
    "lot_number": {
      "type": "string"
    },
    "expiry_date": {
      "type": "string",
      "format": "date"
    },
    "date_received": {
      "type": "string",
      "format": "date"
    },
    "date_opened": {
      "type": "string",
      "format": "date"
    },
    "quantity_in_stock": {
      "type": "number",
      "default": 0
    },
    "unit": {
      "type": "string",
      "description": "e.g. bottle, kit, mL, test strip"
    },
    "storage_condition": {
      "type": "string",
      "enum": [
        "room_temp",
        "refrigerated",
        "frozen",
        "protected_light"
      ]
    },
    "storage_location": {
      "type": "string",
      "description": "e.g. Shelf A3, Fridge 2"
    },
    "reorder_level": {
      "type": "number",
      "default": 5
    },
    "requires_cold_chain": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "discontinued",
        "expired"
      ],
      "default": "active"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "category",
    "expiry_date"
  ]
}